# PostHog player-pattern telemetry (src/lib/analytics.ts).
# Copy to .env.local (gitignored via *.local) and fill in your project key from
# eu.posthog.com. Without a key, analytics is a silent no-op. Set the same
# vars as Heroku config vars so production builds get them; Android builds
# bake them in at `npm run build` time.
VITE_POSTHOG_KEY=
# Optional; defaults to the EU cloud ingestion host.
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Dev builds stay silent even with a key; set to 1 to send events from dev.
# VITE_POSTHOG_DEV=1
